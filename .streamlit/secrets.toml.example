# Copy this file to `secrets.toml` in this folder (that file is gitignored).
# Streamlit Cloud: paste the same keys in App settings → Secrets.
#
# Groq: https://console.groq.com/keys

GROQ_API_KEY = "gsk_your_key_here"

# Optional: shared password shown before the app loads (leave unset for no gate).
# APP_ACCESS_PASSWORD = "change-me"

# Alternative layout for Groq (instead of top-level GROQ_API_KEY):
# [groq]
# api_key = "gsk_your_key_here"

# ----- White-label branding (optional) -----
# [branding]
# app_name = "Acme SOP Studio"
# tagline = "Operational excellence"
# page_title = "Acme · SOP Studio"
# logo_url = "https://example.com/logo.png"
# logo_path = ".streamlit/logo.png"
# primary_color = "#0A74DA"
# secondary_color = "#4338CA"
# accent_color = "#059669"
# hide_powered_by = false

# Env overrides (same keys): BRAND_APP_NAME, BRAND_TAGLINE, BRAND_PAGE_TITLE,
# BRAND_LOGO_URL, BRAND_LOGO_PATH, BRAND_PRIMARY_COLOR, BRAND_SECONDARY_COLOR,
# BRAND_ACCENT_COLOR, BRAND_HIDE_POWERED_BY (= true/1/yes)
